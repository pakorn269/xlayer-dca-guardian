# XLayer DCA Guardian Environment Configuration
# ENVIRONMENT can be 'testnet' or 'mainnet'
ENVIRONMENT=testnet
# REQUIRE_TESTNET=true will force the app to ignore all mainnet requests and lock execution to testnet
REQUIRE_TESTNET=true

# XLayer RPC (optional if using OKX OnchainOS which manages connections automatically)
XLAYER_RPC=https://rpc.xlayer.tech

# OnchainOS automatically handles API credentials securely via its CLI (TEE signatures).
# If you are passing any other AI APIs, add them here.
OLLAMA_API_KEY=your_api_key_here
OLLAMA_API_URL=https://api.ollama.ai/v1/chat/completions

